<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile</title>
    <meta name="description" content="<%= username %>'s Social Media Handle" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Inter", sans-serif;
      }
      .display {
        font-family: "Fraunces", serif;
      }
      .mono {
        font-family: "JetBrains Mono", monospace;
      }
      body {
        background:
          radial-gradient(
            circle at 15% 10%,
            rgba(99, 91, 255, 0.18),
            transparent 45%
          ),
          radial-gradient(
            circle at 85% 90%,
            rgba(255, 158, 87, 0.14),
            transparent 45%
          ),
          #100f14;
        min-height: 100vh;
      }
      .card {
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.045),
          rgba(255, 255, 255, 0.02)
        );
        border: 1px solid rgba(255, 255, 255, 0.09);
        backdrop-filter: blur(20px);
      }
      .avatar-ring {
        background: conic-gradient(from 180deg, #635bff, #ff9e57, #635bff);
        padding: 3px;
      }
      .status-dot {
        box-shadow: 0 0 0 3px #100f14;
      }
    </style>
  </head>
  <body class="flex items-center justify-center p-6">
    <main class="w-full max-w-sm">
      <section
        class="card rounded-3xl p-8 w-full max-w-sm shadow-2xl shadow-black/40"
      >
        <div class="flex items-start justify-between mb-6">
          <div class="avatar-ring rounded-full">
            <img
              src="<%= profilePic %>"
              class="w-24 h-24 rounded-full object-cover block"
              alt="<%= username %>'s Profile Picture"
            />
          </div>
          <span
            class="mono text-[11px] tracking-wider text-emerald-300/90 bg-emerald-400/10 border border-emerald-400/20 rounded-full px-3 py-1.5 flex items-center gap-1.5 mt-2"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-emerald-400 status-dot"
            ></span>
            ONLINE
          </span>
        </div>

        <h2 class="display text-3xl font-medium text-white tracking-tight">
          <%= username %>
        </h2>
        <p class="mono text-xs text-white/40 mt-1 mb-4">
          @<%= handle %> · joined 2024
        </p>

        <p class="text-white/65 text-[15px] leading-relaxed"><%= bio %></p>

        <div class="flex gap-2 mt-6">
          <button
            class="flex-1 bg-white text-[#100F14] text-sm font-medium rounded-xl py-2.5 hover:bg-white/90 transition-colors"
          >
            Follow
          </button>
          <button
            class="px-4 border border-white/15 text-white/80 text-sm rounded-xl py-2.5 hover:bg-white/5 transition-colors"
          >
            Message
          </button>
        </div>
      </section>
    </main>
  </body>
  <script src="/script.js"></script>
</html>
